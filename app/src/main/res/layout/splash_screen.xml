<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_sc"> <ImageView
    android:id="@+id/logo"
    android:layout_width="50dp"
    android:layout_height="50dp"
    android:layout_marginTop="40dp"
    android:src="@drawable/logo"
    android:scaleType="fitCenter"
    android:contentDescription="Logo Icon"
    app:layout_constraintTop_toTopOf="parent"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintEnd_toEndOf="parent" />

    <ImageView
        android:id="@+id/img_logo"
        android:layout_width="157dp"
        android:layout_height="44dp"
        android:layout_marginTop="10dp"
        android:scaleType="fitCenter"
        android:src="@drawable/logo_sc"
        android:contentDescription="Logo Text"
        app:layout_constraintTop_toBottomOf="@id/logo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <ImageView
        android:id="@+id/img_rec"
        android:layout_width="match_parent"
        android:layout_height="692dp"
        android:layout_marginTop="20dp"
        android:src="@drawable/rec_sc"
        android:scaleType="fitXY"
        android:contentDescription="Rectangle Background Pemanis"
        app:layout_constraintTop_toBottomOf="@id/img_logo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="40dp"
        android:background="@drawable/rec_sc_2"
        android:paddingHorizontal="32dp"
        android:paddingTop="50dp"
        app:layout_constraintTop_toBottomOf="@id/img_logo"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/img_get_started"
            android:layout_width="240dp"
            android:layout_height="60dp"
            android:src="@drawable/teks_sc"
            android:scaleType="fitCenter"
            android:contentDescription="Text Get Started"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <ImageView
            android:id="@+id/btn_signup"
            android:layout_width="344dp"
            android:layout_height="71dp"
            android:layout_marginTop="128dp"
            android:src="@drawable/sign_up_sc"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="Tombol Sign Up"
            app:layout_constraintTop_toBottomOf="@id/img_get_started"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <ImageView
            android:id="@+id/btn_signin"
            android:layout_width="344dp"
            android:layout_height="71dp"
            android:layout_marginTop="16dp"
            android:src="@drawable/sign_in_sc"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="Tombol Sign In"
            app:layout_constraintTop_toBottomOf="@id/btn_signup"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.constraintlayout.widget.ConstraintLayout>