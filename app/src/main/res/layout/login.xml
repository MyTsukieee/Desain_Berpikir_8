<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_sc"> <ImageView
    android:id="@+id/btn_back_login"
    android:layout_width="30dp"
    android:layout_height="30dp"
    android:layout_marginStart="20dp"
    android:layout_marginTop="30dp"
    android:clickable="true"
    android:focusable="true"
    android:contentDescription="Back Button"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/logo_login"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:layout_marginTop="40dp"
        android:src="@drawable/logo"
        android:scaleType="fitCenter"
        android:contentDescription="Logo Icon"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <ImageView
        android:id="@+id/img_logo_login"
        android:layout_width="157dp"
        android:layout_height="44dp"
        android:layout_marginTop="10dp"
        android:scaleType="fitCenter"
        android:src="@drawable/logo_sc"
        android:contentDescription="Logo Text"
        app:layout_constraintTop_toBottomOf="@id/logo_login"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <ImageView
        android:id="@+id/img_rec_login"
        android:layout_width="match_parent"
        android:layout_height="692dp"
        android:layout_marginTop="20dp"
        android:src="@drawable/rec_sc"
        android:scaleType="fitXY"
        android:contentDescription="Rectangle Background Pemanis"
        app:layout_constraintTop_toBottomOf="@id/img_logo_login"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="40dp"
        android:background="@drawable/rec_sc_2"
        android:paddingHorizontal="32dp"
        android:paddingTop="45dp"
        app:layout_constraintTop_toBottomOf="@id/img_logo_login"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tv_title_login"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Welcome Back"
            android:textColor="#18476E"
            android:textSize="28sp"
            android:textStyle="bold"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tv_subtitle_login"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Enter your details below"
            android:textColor="#555555"
            android:textSize="15sp"
            android:layout_marginTop="6dp"
            app:layout_constraintTop_toBottomOf="@id/tv_title_login"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <EditText
            android:id="@+id/et_email_login"
            android:layout_width="match_parent"
            android:layout_height="45dp"
            android:layout_marginTop="40dp"
            android:background="@drawable/bg"
            android:hint="Email"
            android:textColorHint="#999999"
            android:textColor="#333333"
            android:paddingHorizontal="20dp"
            android:inputType="textEmailAddress"
            android:textSize="15sp"
            app:layout_constraintTop_toBottomOf="@id/tv_subtitle_login" />

        <EditText
            android:id="@+id/et_password_login"
            android:layout_width="match_parent"
            android:layout_height="45dp"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg"
            android:hint="Password"
            android:textColorHint="#999999"
            android:textColor="#333333"
            android:paddingHorizontal="20dp"
            android:inputType="textPassword"
            android:textSize="15sp"
            app:layout_constraintTop_toBottomOf="@id/et_email_login" />

        <LinearLayout
            android:id="@+id/layout_signup_link"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="20dp"
            app:layout_constraintBottom_toTopOf="@id/btn_signin_submit"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Don’t have an account? "
                android:textColor="#555555"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/tv_link_signup"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sign Up."
                android:textColor="#4AA2CC"
                android:textSize="13sp"
                android:textStyle="bold"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>

        <ImageView
            android:id="@+id/btn_signin_submit"
            android:layout_width="344dp"
            android:layout_height="71dp"
            android:layout_marginBottom="25dp"
            android:src="@drawable/sign_in_sc"
            android:scaleType="fitXY"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="Tombol Sign In"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.constraintlayout.widget.ConstraintLayout>